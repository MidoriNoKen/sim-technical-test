{
  "info": {
    "_postman_id": "c1f7a0cb-1b2c-46cc-9ee0-d2d3b8c49d8a",
    "name": "Solutech Backend Test",
    "description": "Comprehensive Postman collection for the Solutech Backend Technical Test API. Includes folders for Auth, Products, and Orders endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseJson = pm.response.json();",
                  "if (responseJson.success && responseJson.data && responseJson.data.token) {",
                  "    pm.collectionVariables.set(\"token\", responseJson.data.token);",
                  "    console.log(\"Token automatically set to collection variables.\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@solutech.id\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Authenticates user credentials and returns a JWT token. Also sets the token to collection variables automatically upon success."
          },
          "response": []
        }
      ]
    },
    {
