                  "key": "page",
                  "value": "1",
                  "description": "Page index (1-based)"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Items count limit"
                },
                {
                  "key": "search",
                  "value": "Mouse",
                  "description": "Case-insensitive product name filter"
                }
              ]
